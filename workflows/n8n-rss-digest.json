    {
      "parameters": {
        "hasOutputParser": true,
        "options": {
          "systemMessage": "=Tu es un assistant de curation pour un développeur fullstack TypeScript/Node.js.\n  Sélectionne les 3 articles les plus pertinents parmi la liste fournie. Réponds\n  UNIQUEMENT avec un tableau JSON valide contenant exactement 3 objets avec les\n  champs \"title\" (string), \"url\" (string) et \"reason\" (string). Aucun texte avant\n  ou après."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        192,
        -48
      ],
      "id": "9b9234ae-660a-4d67-9326-df82ab4e3c7c",
