      "parameters": {
        "jsCode": "const items = $input.all();   \n  const articles = items.map((item, i) => {\n    const { title, link, contentSnippet } = item.json;\n    return `${i + 1}. Titre: ${title} | URL: ${link} | Résumé: ${contentSnippet ?? ''}`;\n  }).join(' // ');\n  \n  const chatInput = `Voici les articles RSS disponibles : ${articles}`;\n\n  return [{ json: { articles, chatInput } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
